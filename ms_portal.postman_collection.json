          ]
        },
        {
          "name": "Borrar feedback",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/feedbacks/{{idFeedback}}", "host": ["{{baseUrl}}"], "path": ["api","v1","feedbacks","{{idFeedback}}"] }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test(\"status ok\", function () { pm.expect(pm.response.code).to.be.oneOf([200,204]); });" ] } }
          ]
        }
      ]
    }
  ]
}
